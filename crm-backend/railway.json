{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm ci && npm run build",
    "nixpacksConfig": {
      "providers": ["node"],
      "node": {
        "version": "20"
      }
    }
  },
  "deploy": {
    "startCommand": "npm run start",
    "restartPolicyType": "ON_FAILURE",
    "healthCheckPath": "/health",
    "healthCheckTimeout": 100
  }
}
